@model RoleViewModel
@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Edit @Model.RoleName User </h1>
<div asp-validation-summary="All"></div>
<form asp-action="Edit" enctype="multipart/form-data">
    <div>
        <label class="col-form-label" asp-for="Id"></label>
        <input readonly class=" form-control" asp-for="Id" />
    </div>
    <div class="form-group">
        <label class="col-form-label" asp-for="RoleName"></label>
        <input class=" form-control" asp-for="RoleName" />
        <span asp-validation-for="RoleName" class="text-danger"></span>
    </div>
    <input type="submit" value="Save" class="btn btn-primary" />
    <a asp-action="Index" class="btn btn-light">Back To List</a>
</form>
@section ClientSideValidation {
    <partial name="_ValidationScriptsPartial" />
}

