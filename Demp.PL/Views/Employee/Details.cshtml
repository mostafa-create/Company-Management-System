@model EmployeeViewModel
@{
	ViewData["Title"] = "Details";
}

<h1>Employee @Model.Name Details</h1>
<div class="form-group">
    <label class="col-form-label" asp-for="Name"></label><!--will get the type and the name of the attripute-->
    <input readonly class=" form-control" asp-for="Name" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="Age"></label>
    <input readonly class=" form-control" asp-for="Age" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="Salary"></label>
    <input readonly class=" form-control" asp-for="Salary" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="Address"></label>
    <input readonly class=" form-control" asp-for="Address" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="EmailAddress"></label>
    <input readonly class=" form-control" asp-for="EmailAddress" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="Phone"></label>
    <input readonly class=" form-control" asp-for="Phone" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="HireDate"></label>
    <input readonly class=" form-control" asp-for="HireDate" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="IsActive"></label>
    <input readonly class=" form-control" asp-for="IsActive" />
</div>
<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit</a>
<a asp-action="Index" class="btn btn-light">Back To List</a>


