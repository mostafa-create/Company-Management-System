@model UserViewModel
@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Edit @Model.FName User </h1>
<div asp-validation-summary="All"></div>
<form asp-action="Edit" enctype="multipart/form-data">
    <div class="form-group">
        <label class="col-form-label" asp-for="FName"></label>
        <input class=" form-control" asp-for="FName" />
        <span asp-validation-for="FName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label class="col-form-label" asp-for="LName"></label>
        <input class=" form-control" asp-for="LName" />
        <span asp-validation-for="LName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label class="col-form-label" asp-for="PhoneNumber"></label>
        <input class=" form-control" asp-for="PhoneNumber" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>
    <input type="submit" value="Save" class="btn btn-primary" />
    <a asp-action="Index" class="btn btn-light">Back To List</a>
</form>
@section ClientSideValidation {
    <partial name="_ValidationScriptsPartial" />
}

